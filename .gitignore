# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# cargo-fuzz (crates/leanr_olean/fuzz is excluded from the workspace)
crates/leanr_olean/fuzz/artifacts/
crates/leanr_olean/fuzz/target/
crates/leanr_olean/fuzz/Cargo.lock

# cargo-fuzz (crates/leanr_syntax/fuzz is excluded from the workspace)
crates/leanr_syntax/fuzz/artifacts/
crates/leanr_syntax/fuzz/target/
crates/leanr_syntax/fuzz/Cargo.lock

# `mise run fuzz:syntax` / `parse:acceptance` mutate this corpus dir with
# hundreds of untracked discovered inputs per run. This ignores the
# directory for the purpose of new/untracked files only — git ignore rules
# never un-track already-committed paths, so the 15 committed seed
# fixtures under parse_module/ stay tracked and their edits still show up
# in `git status` normally (verified: `git ls-files` still lists all 15
# after this rule).
crates/leanr_syntax/fuzz/corpus/parse_module/

# Mathlib checkout + prebuilt .oleans (M1-final Mathlib-scale acceptance
# sweep). Cloned by `scripts/mathlib-fetch.sh`; local, network-fetched, not
# committed. (No separate `.lean4checker/` clone: `scripts/bench-mathlib.sh`
# benchmarks against the toolchain-bundled `leanchecker` binary instead —
# see that script for why.)
.mathlib/
